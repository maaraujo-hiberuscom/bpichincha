const respuesta = insomnia.response.text();

function obtenerCampo(xml, nombreCampo) {
  if (!xml) return '';

  const expresion = new RegExp(
    `<(?:\\w+:)?${nombreCampo}[^>]*>([\\s\\S]*?)<\\/(?:\\w+:)?${nombreCampo}>`,
    'i'
  );

  const resultado = xml.match(expresion);
  return resultado ? resultado[1].trim() : '';
}

const errorLegado = {
  codigo: obtenerCampo(respuesta, 'codigo'),
  mensaje: obtenerCampo(respuesta, 'mensaje'),
  mensajeNegocio: obtenerCampo(respuesta, 'mensajeNegocio'),
  tipo: obtenerCampo(respuesta, 'tipo'),
  recurso: obtenerCampo(respuesta, 'recurso'),
  componente: obtenerCampo(respuesta, 'componente'),
  backend: obtenerCampo(respuesta, 'backend')
};

insomnia.environment.set(
  'wsproductos0248_error_legado',
  JSON.stringify(errorLegado)
);

insomnia.environment.set(
  'wsproductos0248_respuesta_legado',
  respuesta
);

insomnia.test('LEGADO - HTTP exitoso', () => {
  insomnia.expect(insomnia.response.status).to.be.oneOf([200, 400, 500]);
});

console.log('Error legado:', errorLegado);

