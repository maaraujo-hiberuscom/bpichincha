2. Request MIGRADO

Nombre:

MIGRADO - ActualizarOficialCliente31

En la pestaña Tests del request migrado pega esto:

const migradoResponse = insomnia.response.text();

function getTag(xml, tag) {
  const match = xml.match(new RegExp(`<${tag}>([\\s\\S]*?)<\\/${tag}>`));
  return match ? match[1].trim() : "";
}

const migrado_codigo = getTag(migradoResponse, "codigo");
const migrado_mensaje = getTag(migradoResponse, "mensaje");
const migrado_mensajeNegocio = getTag(migradoResponse, "mensajeNegocio");
const migrado_tipo = getTag(migradoResponse, "tipo");
const migrado_recurso = getTag(migradoResponse, "recurso");
const migrado_componente = getTag(migradoResponse, "componente");
const migrado_backend = getTag(migradoResponse, "backend");

insomnia.test("MIGRADO - Status 200", () => {
  insomnia.expect(insomnia.response.code).to.eql(200);
});

insomnia.test("Comparar codigo Legacy vs Migrado", () => {
  insomnia.expect(migrado_codigo).to.eql(insomnia.environment.get("legacy_codigo"));
});

insomnia.test("Comparar mensaje Legacy vs Migrado", () => {
  insomnia.expect(migrado_mensaje).to.eql(insomnia.environment.get("legacy_mensaje"));
});

insomnia.test("Comparar mensajeNegocio Legacy vs Migrado", () => {
  insomnia.expect(migrado_mensajeNegocio).to.eql(insomnia.environment.get("legacy_mensajeNegocio"));
});

insomnia.test("Comparar tipo Legacy vs Migrado", () => {
  insomnia.expect(migrado_tipo).to.eql(insomnia.environment.get("legacy_tipo"));
});

insomnia.test("Comparar recurso Legacy vs Migrado", () => {
  insomnia.expect(migrado_recurso).to.eql(insomnia.environment.get("legacy_recurso"));
});

insomnia.test("Comparar componente Legacy vs Migrado", () => {
  insomnia.expect(migrado_componente).to.eql(insomnia.environment.get("legacy_componente"));
});

insomnia.test("Comparar backend Legacy vs Migrado", () => {
  insomnia.expect(migrado_backend).to.eql(insomnia.environment.get("legacy_backend"));
});

